{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://posthub-2i6j.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://posthub-2i6j.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets).*)",
      "destination": "/index.html"
    }
  ]
}
